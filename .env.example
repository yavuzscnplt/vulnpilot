# VulnPilot yapılandırması — bu dosyayı .env olarak kopyalayıp doldur.
# .env asla commit edilmez (.gitignore'da).

# Claude API anahtarı (AI beyni için). Boşsa VulnPilot deterministik
# heuristik moda düşer ve yine uçtan uca çalışır.
ANTHROPIC_API_KEY=

# Kullanılacak model (varsayılan: claude-sonnet-5)
VULNPILOT_MODEL=claude-sonnet-5

# Zaman aşımları (saniye)
VULNPILOT_HTTP_TIMEOUT=15
VULNPILOT_TOOL_TIMEOUT=180

# Rapor çıktı klasörü
VULNPILOT_OUTPUT_DIR=reports
